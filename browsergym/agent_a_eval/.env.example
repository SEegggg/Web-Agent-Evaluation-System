# ============================================================
# Agent A 自动评审系统 — 环境变量模板
# ============================================================
# 使用方法:
#   1. 复制此文件为 .env:  cp .env.example .env
#   2. 填入你的真实密钥和密码
#   3. .env 已加入 .gitignore，不会被提交到 Git
#
# 配置优先级:
#   系统环境变量（export） > .env 文件 > config.yaml
# ============================================================

# ──────────────────────────────────────────────────────────
# 驱动 Agent LLM（操作浏览器、执行测试的 Agent）
# ──────────────────────────────────────────────────────────
# 如果 config.yaml 中 provider=openai，设置以下变量:
OPENAI_API_KEY=sk-your-key-here
# OPENAI_BASE_URL=https://api.deepseek.com/v1

# 如果 config.yaml 中 provider=anthropic，设置以下变量:
# ANTHROPIC_API_KEY=sk-ant-api03-your-key-here

# ──────────────────────────────────────────────────────────
# 评审 Agent LLM（独立于浏览器、对结果评分的 Agent）
# ──────────────────────────────────────────────────────────
# 如果评审 Agent 使用和驱动 Agent 相同的 API，无需额外设置
# 如果使用不同的 provider 或 key，设置以下变量:
# EVALUATOR_OPENAI_API_KEY=sk-your-evaluator-key-here
# 注：评审 Agent 目前与驱动 Agent 共用 OPENAI_API_KEY / ANTHROPIC_API_KEY 环境变量

# ──────────────────────────────────────────────────────────
# Agent A 登录凭据
# ──────────────────────────────────────────────────────────
AGENT_A_EVAL_LOGIN_URL=
AGENT_A_EVAL_LOGIN_USERNAME=
AGENT_A_EVAL_LOGIN_PASSWORD=
