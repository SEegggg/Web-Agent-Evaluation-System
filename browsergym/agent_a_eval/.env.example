# ============================================================
# Agent A 自动评审系统 — 环境变量模板
# ============================================================
# 使用方法:
#   1. 复制此文件为 .env:  cp .env.example .env
#   2. 填入你的真实密钥和密码
#   3. .env 已加入 .gitignore，不会被提交到 Git
#
# 配置优先级:
#   系统环境变量（export） > .env 文件 > config.yaml
# ============================================================

# ──────────────────────────────────────────────────────────
# 驱动 Agent LLM（操作浏览器、执行测试的 Agent）
# ──────────────────────────────────────────────────────────
# 驱动与评审 Agent 共用以下配置（config.yaml 中 provider=openai）:
OPENAI_API_KEY=sk-your-key-here
OPENAI_BASE_URL=https://api.deepseek.com/v1

# 如果用 anthropic，改为:
# ANTHROPIC_API_KEY=sk-ant-api03-your-key-here
# ANTHROPIC_BASE_URL=https://api.anthropic.com

# ──────────────────────────────────────────────────────────
# Agent A 登录凭据
# ──────────────────────────────────────────────────────────
AGENT_A_EVAL_LOGIN_URL=
AGENT_A_EVAL_LOGIN_USERNAME=
AGENT_A_EVAL_LOGIN_PASSWORD=
